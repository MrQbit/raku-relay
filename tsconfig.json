{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "bun-types"],
    "baseUrl": ".",
    "paths": {
      "@raku-relay/contracts": ["packages/contracts/src/index.ts"],
      "@raku-relay/config": ["packages/config/src/index.ts"],
      "@raku-relay/auth": ["packages/auth/src/index.ts"],
      "@raku-relay/db": ["packages/db/src/index.ts"],
      "@raku-relay/logging": ["packages/logging/src/index.ts"]
    }
  },
  "include": ["apps/**/*.ts", "packages/**/*.ts"]
}
