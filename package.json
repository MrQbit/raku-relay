{
  "name": "raku-relay",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun --watch apps/api/src/index.ts",
    "dev:runner": "bun --watch apps/runner/src/index.ts",
    "db:migrate:psql": "psql \"$RAKU_POSTGRES_URL\" -f packages/db/src/migrations/0000_initial.sql",
    "build": "bun run build:api && bun run build:runner",
    "build:api": "bun build apps/api/src/index.ts --outfile dist/apps/api/index.mjs --target bun",
    "build:runner": "bun build apps/runner/src/index.ts --outfile dist/apps/runner/index.mjs --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "audit:relay-migration": "python3 scripts/audit-relay-migration.py",
    "verify": "bun run build && bun run typecheck && bun run test && bun run audit:relay-migration"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.3",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.3",
    "@fastify/websocket": "^11.2.0",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.6.0",
    "jose": "^6.1.0",
    "postgres": "^3.4.7",
    "redis": "^5.8.2",
    "ws": "^8.18.3",
    "zod": "^4.1.11"
  }
}
